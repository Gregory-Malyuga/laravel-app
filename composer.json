{
    "name": "laravel/laravel",
    "description": "The skeleton application for the Laravel framework.",
    "license": "MIT",
    "type": "project",
    "keywords": [
        "laravel",
        "framework"
    ],
    "require": {
        "php": "^8.5",
        "darkaonline/l5-swagger": "^11.0",
        "elasticsearch/elasticsearch": "^8.0",
        "laravel/framework": "^13.8",
        "laravel/octane": "^2.17",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "spatie/laravel-data": "^4.23"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "brianium/paratest": "^7.20",
        "deptrac/deptrac": "^2.0",
        "ergebnis/composer-normalize": "^2.51",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/App/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Domains\\": "app/Domains/",
            "Shared\\": "app/Shared/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "process-timeout": 0,
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "architecture": "./vendor/bin/deptrac analyse --config-file=deptrac.yaml --fail-on-uncovered --cache-file=.deptrac.cache",
        "codegen": "@php artisan make:domain",
        "codegen:openapi": "@php artisan openapi:generate",
        "composer:normalize": "composer normalize --dry-run --diff",
        "cs:check": "./vendor/bin/pint --test",
        "cs:fix": "./vendor/bin/pint",
        "db:create": "@php -r \"echo 'SQLite :memory: — no create step needed.' . PHP_EOL;\"",
        "db:migrate": "@php -r \"echo 'SQLite :memory: — migrations run via RefreshDatabase in tests.' . PHP_EOL;\"",
        "db:wait": "@php -r \"echo 'SQLite :memory: — no wait step needed.' . PHP_EOL;\"",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "docs:check": "php bin/check-doc-links.php",
        "hooks:install": "git config core.hooksPath .githooks",
        "ide-helper": [
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:models -W -R"
        ],
        "lint:container": "@php artisan route:list --ansi",
        "lint:container:prod": "@php artisan optimize --ansi",
        "lint:php": "find app routes tests database -name '*.php' -print0 | xargs -0 -n1 php -l",
        "lint:yaml": "@php -r \"echo 'No YAML config in Laravel — skipped.' . PHP_EOL;\"",
        "phpstan": "./vendor/bin/phpstan analyse --memory-limit=512M",
        "pre-commit": [
            "@composer:normalize",
            "@codegen:openapi",
            "@ide-helper"
        ],
        "pre-push": [
            "@lint:php",
            "@cs:check",
            "@phpstan",
            "@architecture",
            "@docs:check",
            "@test"
        ],
        "pre-push:fast": [
            "@lint:php",
            "@cs:check",
            "@phpstan",
            "@docs:check",
            "@test"
        ],
        "psalm": "@phpstan",
        "router:prod": "@php artisan route:cache --ansi",
        "setup": [
            "composer install",
            "@hooks:install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "@php artisan elasticsearch:setup",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "smoke": "@php artisan about --ansi",
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan migrate --force --ansi",
            "@php artisan test"
        ],
        "test:parallel": [
            "@php artisan config:clear --ansi",
            "@php artisan migrate --force --ansi",
            "@php vendor/bin/paratest --processes=4 --runner=WrapperRunner"
        ]
    },
    "$schema": "https://getcomposer.org/schema.json"
}
