{
  "permissions": {
    "allow": [
      "Bash(docker compose exec*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose logs*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git branch*)",
      "Bash(git rebase*)",
      "Bash(git stash*)",
      "Bash(git show*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(mkdir*)",
      "Bash(chmod*)",
      "Bash(rm -f *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "TodoWrite"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git remote*)",
      "Bash(git clone*)",
      "Bash(rm -rf*)",
      "Write(.env*)",
      "Edit(.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-pint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-state-reminder.sh"
          }
        ]
      }
    ]
  }
}
